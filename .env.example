# Kopiraj u .env i popuni. Ne commituj .env u git.
#
# =============================================================================
# BAZA (MySQL / MariaDB)
# =============================================================================
DATABASE_URL=mysql://root:@127.0.0.1:3306/ime_baze
# Server baze: utf8mb4 / utf8mb4_unicode_ci. Node mysql2 koristi charset utf8mb4 (lib/create-mysql-pool.ts).
# Sa lozinkom: mysql://user:PASSWORD@host:3306/ime_baze  (@ u lozinci -> %40)

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=ime_baze

# =============================================================================
# SEED PRVOG ADMINA: npm run seed:admin
# Nova lozinka za postojeceg: $env:SEED_UPDATE_PASSWORD="1"; npm run seed:admin
# Skripte ucitavaju .env preko Node --env-file (vidi package.json).
# Podrazumijevani SUPER_ADMIN email (vidi lib/auth/constants.ts); moze override:
# SUPER_ADMIN_EMAIL=dalibor.djukic.pg@gmail.com
# =============================================================================
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=

# =============================================================================
# AUTH (sesija, strogi login)
# =============================================================================
# Trajanje cookie sesije u sekundama (npr. 2592000 = 30 dana).
# AUTH_SESSION_MAX_AGE_SEC=2592000
# Zahtijevaj potvrdjeni email prije admin prijave: 1 = da.
# AUTH_REQUIRE_EMAIL_VERIFIED=0

# =============================================================================
# ADMIN — privatna ruta (skriva /admin)
# =============================================================================
# Stara `/admin/*` ruta vise nije dostupna (vraca 404). Sve admin stranice
# (login, dashboard, itd.) sada zive na ADMIN_BASE_PATH. Da bi promijenio,
# postavi obje vrijednosti istovremeno (server + klijent) i restartuj server.
# Dozvoljeno: pocinje sa "/", samo [a-z0-9-], max 64 znaka.
ADMIN_BASE_PATH=/hrc-panel-74x
NEXT_PUBLIC_ADMIN_BASE_PATH=/hrc-panel-74x

# =============================================================================
# LOGIN RATE LIMIT (in-memory, jedan Node proces)
# =============================================================================
# Maks. broj neuspjelih login pokusaja unutar prozora (default 5).
# LOGIN_MAX_ATTEMPTS=5
# Prozor pracenja u milisekundama (default 15 min).
# LOGIN_WINDOW_MS=900000
# Trajanje blokade nakon prekoracenja (default 15 min).
# LOGIN_BLOCK_MS=900000

# =============================================================================
# Automatski prevod --- admin "Prevedi EN/RU" + javni sajt pri prikazu
# =============================================================================
# TRANSLATE_PROVIDER=openai | azure | deepl | google | libre | mymemory
# Ako nije postavljeno, sistem automatski bira provajder po dostupnim kljucevima.
# Prioritet auto-detekcije: openai > azure > deepl > google > libre > mymemory
#
# --- OpenAI (ChatGPT API) ---
# platform.openai.com -> API keys. NE commituj kljuc u git.
TRANSLATE_PROVIDER=openai
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
#
# --- Microsoft Azure AI Translator ---
# Trajno BESPLATNO 2.000.000 znakova/mj (F0 tier, bez kreditne kartice na Azure Free nalogu).
# Registracija:
#   1. https://portal.azure.com -> "Create resource" -> "Translator" -> F0 (Free)
#   2. Nakon kreiranja: "Keys and Endpoint" -> kopiraj Key 1 i Region
#   3. Endpoint je opcionalan (podrazumijevana vrijednost je vec ispravna)
# TRANSLATE_PROVIDER=azure
# AZURE_TRANSLATOR_KEY=
# AZURE_TRANSLATOR_REGION=westeurope
# AZURE_TRANSLATOR_ENDPOINT=https://api.cognitive.microsofttranslator.com
#
# --- BESPLATNO bez kartice (alternativa bez Azure naloga) ---
# MyMemory: bez registracije ~5000 znakova/dan; sa emailom ~50000/dan:
# TRANSLATE_PROVIDER=mymemory
# MYMEMORY_EMAIL=tvoj@email.com
#
# LibreTranslate (javni server ili self-host):
# TRANSLATE_PROVIDER=libre
# LIBRETRANSLATE_URL=https://libretranslate.com
# LIBRETRANSLATE_API_KEY=   # ponekad trazi besplatan kljuc na portal.libretranslate.com
#
# --- DeepL ---
# Stari "API Free" (500k/mj.) vise nije za nove naloge. Novi "Developer" ~1M znakova ukupno.
# DEEPL_API_KEY=xxxxxxxx:fx
#
# --- Google Cloud ---
# "$300 besplatno" = probni period (~90 dana), NE trajno besplatno -- trazi karticu.
# GOOGLE_TRANSLATE_API_KEY=AIza...
#
# Kad je provajder aktivan: /en i /ru prevode ME pri prikazu (kes ~14 dana).
# U PRODUKCIJI obavezno isključiti — prevodi se generišu iz admin panela (Admin → Prevodi).
AUTO_TRANSLATE_ON_VIEW=0

# =============================================================================
# PRODUKCIJA (Hostinger / humanreproduction.com)
# =============================================================================
# NEXT_PUBLIC_SITE_URL=https://humanreproduction.com
# SITE_URL=https://humanreproduction.com
# APP_URL=https://humanreproduction.com
#
# =============================================================================
# DEV server --- uskladi port i javni URL
# =============================================================================
DEV_PORT=7392
# Slušaj na svim mrežnim interfejsima da telefon na istom Wi-Fi može LAN IP (vidi poruku pri `npm run dev`).
# Da isključiš: DEV_HOST=127.0.0.1
# DEV_HOST=0.0.0.0
NEXT_PUBLIC_SITE_URL=http://localhost:7392
#
# Javni link za test (bez Vercel-a): dva terminala --- `npm run dev`, zatim `npm run share:dev`.
# Ako localtunnel ne radi: `npm run share:dev:cf` (potreban cloudflared u PATH; vidi poruku skripte).
# Stámpa https://....loca.lt; drzi oba procesa upaljena. Prvo otvaranje tunela: "Continue" na upozorenju.
# `allowedDevOrigins` u next.config.ts mora pokriti tunel --- nakon izmjene configa restartuj dev server.
# Opciono za apsolutne URL-ove dok dijelis tunel: privremeno stavi isti NEXT_PUBLIC_SITE_URL kao link sa share:dev.

# =============================================================================
# WordPress ETL (ziva baza): npm run migrate:wp-etl
# =============================================================================
# WP_DATABASE_URL=mysql://root:@127.0.0.1:3306/stara_wp_baza
# Ili:
# WP_MYSQL_HOST=127.0.0.1
# WP_MYSQL_PORT=3306
# WP_MYSQL_USER=root
# WP_MYSQL_PASSWORD=
# WP_MYSQL_DATABASE=stara_wp_baza
#
# WP_TABLE_PREFIX=wp_
# MIGRATE_POST_TYPES=post
# MIGRATE_BATCH_SIZE=100
# MIGRATE_CONTENT_ROLE=blog
# MIGRATE_APPEND_META_JSON=0
#
# Stari WordPress uploads URL u post_content (i SQL importu) -> /uploads/ ili CDN:
# MIGRATE_OLD_UPLOADS_PREFIX=https://stari-sajt.com/wp-content/uploads
# MIGRATE_NEW_UPLOADS_PREFIX=/uploads/
# Eksplicitni origin za interne linkove (<a href>) ako nije isti kao kod uploads URL-a:
# MIGRATE_OLD_SITE_ORIGIN=https://stari-sajt.com

# Kontakt forma (public API + PDF + Resend) -> primalac: info@humanreproduction.com
# ---------------------------------------------------------------------------
# Primalac kontakt forme (PDF + email). Podrazumijevano info@humanreproduction.com:
# CONTACT_FORM_NOTIFY_EMAIL=info@humanreproduction.com
# (Za tekst u podnoZju PDF-a mozete override-ovati samo prikaz):
# CONTACT_PDF_CLINIC_NAME="Human Reproduction Center"
# CONTACT_PDF_CLINIC_EMAIL=info@humanreproduction.com
# Jednoredna adresa u podnozju stampanog PDF-a (opciono):
# CONTACT_PDF_CLINIC_ADDRESS="bb XVI Ulica, Budva 85310"
# Logo u PDF-u (opcionalno; podrazumijevano public/logo-hrc-budva.png):
# CONTACT_PDF_LOGO_PATH=public/logo-hrc-budva.png
# Salt za hash posjetioca u internoj analitici (preporuceno u produkciji):
# ANALYTICS_VISITOR_SALT=nasumicno-dugacki-niz
# Resend: https://resend.com --- nakon registracije dodajte API kljuc i verifikujte domen za "from".
# Na besplatnom nivou dodajte i info@humanreproduction.com kao odrediste (Recipients), ako trazi.
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM="Human Reproduction Center <noreply@vas-verifikovani-domen.com>"
# Test slanja sa produkcije: GET /api/health/email , POST /api/health/email/test (secret):
# HEALTH_EMAIL_SECRET=nasumicno-dugacki-niz

# =============================================================================
# VERCEL (produkcija 24/7 --- ne koristi share:dev / lokalni tunel)
# =============================================================================
# 1) MySQL u oblaku + DATABASE_URL (mora biti dostupan Vercelu preko interneta).
# 2) Lokalno s tim istim DATABASE_URL: npm run db:migrate (+ seed po potrebi).
# 3) Kod na Git-u (GitHub itd.) pa import repoa u Vercel.
# 4) Na Vercelu (Settings -> Environment Variables), minimum:
#    DATABASE_URL=mysql://...
#    NEXT_PUBLIC_SITE_URL=https://humanreproduction.com
#    (ili tačan URL deploy okruženja; na Hostingeru obavezno produkcijski domen)
# 5) Opciono: ANALYTICS_VISITOR_SALT, RESEND_* --- vidi gore.
# 6) Prevod: AZURE_TRANSLATOR_KEY + AZURE_TRANSLATOR_REGION (ili drugi provajder).
#
# Brzi ispis koraka u terminalu: npm run vercel:checklist
#
# Sablon za Vercel "Import .env": kopiraj `vercel.env.production.example` -> `vercel.env`,
# popuni vrijednosti (vercel.env je u .gitignore), pa uvezi na Vercelu.
