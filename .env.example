# Kopiraj u .env i popuni. Ne commituj .env u git.
#
# =============================================================================
# BAZA (MySQL / MariaDB)
# =============================================================================
DATABASE_URL=mysql://root:@127.0.0.1:3306/ime_baze
# Sa lozinkom: mysql://user:PASSWORD@127.0.0.1:3306/ime_baze  (@ u lozinci → %40)

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=ime_baze

# =============================================================================
# ADMIN SESIJA — min. 32 znaka (npr. slučajan niz)
# =============================================================================
AUTH_SECRET=

# =============================================================================
# SEED PRVOG ADMINA: npm run seed:admin
# Nova lozinka za postojećeg: $env:SEED_UPDATE_PASSWORD="1"; npm run seed:admin
# Skripte učitavaju .env preko Node --env-file (vidi package.json).
# =============================================================================
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=

# =============================================================================
# DEV server — uskladi port i javni URL
# =============================================================================
DEV_PORT=7392
NEXT_PUBLIC_SITE_URL=http://localhost:7392

# =============================================================================
# OPCIONO
# =============================================================================
# RESEND_API_KEY=
