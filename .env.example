# Kopiraj u .env i popuni. Ne commituj .env u git.
#
# =============================================================================
# BAZA (MySQL / MariaDB)
# =============================================================================
DATABASE_URL=mysql://root:@127.0.0.1:3306/ime_baze
# Server baze: utf8mb4 / utf8mb4_unicode_ci. Node mysql2 koristi charset utf8mb4 (lib/create-mysql-pool.ts).
# Sa lozinkom: mysql://user:PASSWORD@host:3306/ime_baze  (@ u lozinci → %40)

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=ime_baze

# =============================================================================
# SEED PRVOG ADMINA: npm run seed:admin
# Nova lozinka za postojećeg: $env:SEED_UPDATE_PASSWORD="1"; npm run seed:admin
# Skripte učitavaju .env preko Node --env-file (vidi package.json).
# Podrazumijevani SUPER_ADMIN email (vidi lib/auth/constants.ts); može override:
# SUPER_ADMIN_EMAIL=dalibor.djukic.pg@gmail.com
# =============================================================================
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=

# =============================================================================
# AUTH (sesija, strogi login)
# =============================================================================
# Trajanje cookie sesije u sekundama (npr. 2592000 = 30 dana).
# AUTH_SESSION_MAX_AGE_SEC=2592000
# Zahtijevaj potvrđen email prije admin prijave: 1 = da.
# AUTH_REQUIRE_EMAIL_VERIFIED=0

# =============================================================================
# DEV server — uskladi port i javni URL
# =============================================================================
DEV_PORT=7392
# Slušaj na svim mrežnim interfejsima da telefon na istom Wi‑Fi može LAN IP (vidi poruku pri `npm run dev`).
# Da isključiš: DEV_HOST=127.0.0.1
# DEV_HOST=0.0.0.0
NEXT_PUBLIC_SITE_URL=http://localhost:7392
#
# Javni link za test (bez Vercel-a): dva terminala — `npm run dev`, zatim `npm run share:dev`.
# Štampa https://….loca.lt; drži oba procesa upaljena. Prvo otvaranje tunela: „Continue“ na upozorenju.
# `allowedDevOrigins` u next.config.ts mora pokriti tunel — nakon izmjene configa restartuj dev server.
# Opciono za apsolutne URL-ove dok dijeliš tunel: privremeno stavi isti NEXT_PUBLIC_SITE_URL kao link sa share:dev.

# =============================================================================
# WordPress ETL (živa baza): npm run migrate:wp-etl
# =============================================================================
# WP_DATABASE_URL=mysql://root:@127.0.0.1:3306/stara_wp_baza
# Ili:
# WP_MYSQL_HOST=127.0.0.1
# WP_MYSQL_PORT=3306
# WP_MYSQL_USER=root
# WP_MYSQL_PASSWORD=
# WP_MYSQL_DATABASE=stara_wp_baza
#
# WP_TABLE_PREFIX=wp_
# MIGRATE_POST_TYPES=post
# MIGRATE_BATCH_SIZE=100
# MIGRATE_CONTENT_ROLE=blog
# MIGRATE_APPEND_META_JSON=0
#
# Stari WordPress uploads URL u post_content (i SQL importu) → /uploads/ ili CDN:
# MIGRATE_OLD_UPLOADS_PREFIX=https://stari-sajt.com/wp-content/uploads
# MIGRATE_NEW_UPLOADS_PREFIX=/uploads/
# Eksplicitni origin za interne linkove (<a href>) ako nije isti kao kod uploads URL-a:
# MIGRATE_OLD_SITE_ORIGIN=https://stari-sajt.com

# Kontakt forma (public API + PDF + Resend) → primalac: info@humanreproduction.com
# ---------------------------------------------------------------------------
# E-pošta sa kontakt forme (uključujući PDF) uvijek se šalje na info@humanreproduction.com.
# (Za tekst u podnožju PDF-a možete override-ovati samo prikaz):
# CONTACT_PDF_CLINIC_NAME="Human Reproduction Center"
# CONTACT_PDF_CLINIC_EMAIL=info@humanreproduction.com
# Jednoredna adresa u podnožju štampanog PDF-a (opciono):
# CONTACT_PDF_CLINIC_ADDRESS="bb XVI Ulica, Budva 85310"
# Logo u PDF-u (opcionalno; podrazumijevano public/logo-hrc-budva.png):
# CONTACT_PDF_LOGO_PATH=public/logo-hrc-budva.png
# Salt za hash posjetioca u internoj analitici (preporučeno u produkciji):
# ANALYTICS_VISITOR_SALT=nasumično-dugacki-niz
# Resend: https://resend.com — nakon registracije dodajte API ključ i verifikujte domen za "from".
# Na besplatnom nivou dodajte i info@humanreproduction.com kao odredište (Recipients), ako traži.
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM="Human Reproduction Center <noreply@vaš-verifikovani-domen.com>"

# =============================================================================
# VERCEL (produkcija 24/7 — ne koristi share:dev / lokalni tunel)
# =============================================================================
# 1) MySQL u oblaku + DATABASE_URL (mora biti dostupan Vercelu preko interneta).
# 2) Lokalno s tim istim DATABASE_URL: npm run db:migrate (+ seed po potrebi).
# 3) Kod na Git-u (GitHub itd.) pa import repoa u Vercel.
# 4) Na Vercelu (Settings → Environment Variables), minimum:
#    DATABASE_URL=mysql://...
#    NEXT_PUBLIC_SITE_URL=https://ime-projekta.vercel.app
#    (nakon prvog deploya zamijeni URL tačnom vrijednošću iz Vercela, pa Redeploy.)
# 5) Opciono: ANALYTICS_VISITOR_SALT, RESEND_* — vidi gore.
#
# Brzi ispis koraka u terminalu: npm run vercel:checklist
