# =============================================================================
# VERCEL / HOSTINGER — Environment Variables (Import .env)
# =============================================================================
#
# Koraci:
#   1) Kopiraj ovaj fajl kao `vercel.env` u korijen projekta
#      (npr. PowerShell: Copy-Item vercel.env.production.example vercel.env)
#   2) Ispuni DATABASE_URL i NEXT_PUBLIC_SITE_URL stvarnim vrijednostima.
#      Fajl `vercel.env` je u .gitignore — ne ide na Git.
#   3) Vercel → Project → Settings → Environment Variables → "Import .env"
#      (Hostinger: hPanel → Node.js → Environment variables)
#   4) Save → Redeploy / restart aplikacije.
#
# DATABASE_URL mora biti JAVNI MySQL (ne 127.0.0.1 osim ako je isti server).
# NEXT_PUBLIC_SITE_URL = kanonski HTTPS domen (produkcija).
#
# =============================================================================

DATABASE_URL=mysql://USER:PASSWORD@HOST:3306/IME_BAZE
NEXT_PUBLIC_SITE_URL=https://humanreproduction.com
SITE_URL=https://humanreproduction.com
APP_URL=https://humanreproduction.com

# --- Mašinski prevod (samo admin panel → Prevodi) ---
# OpenAI se koristi isključivo za bulk generate iz admina, ne pri posjeti sajta.
# OPENAI_API_KEY=sk-...
# AUTO_TRANSLATE_ON_VIEW=0

# --- Opciono (preporučeno u produkciji) ---
# ANALYTICS_VISITOR_SALT=nasumicno-nadji-64-znakova
# RESEND_API_KEY=re________________________________
# RESEND_FROM="Human Reproduction Center <noreply@humanreproduction.com>"
